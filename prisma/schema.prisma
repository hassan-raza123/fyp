// ─── Indirect Assessment (Exit Surveys) ───────────────────────────────────────

model surveys {
  id               Int              @id @default(autoincrement())
  title            String
  description      String?
  courseOfferingId Int
  createdBy        Int
  status           survey_status    @default(draft)
  dueDate          DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  courseOffering   courseofferings  @relation(fields: [courseOfferingId], references: [id])
  creator          users            @relation("SurveyCreator", fields: [createdBy], references: [id])
  questions        survey_questions[]
  responses        survey_responses[]

  @@index([courseOfferingId])
  @@index([createdBy])
}

model survey_questions {
  id           Int                  @id @default(autoincrement())
  surveyId     Int
  ploId        Int?
  question     String
  questionType survey_question_type @default(rating)
  orderIndex   Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  survey       surveys              @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  plo          plos?                @relation(fields: [ploId], references: [id])
  answers      survey_answers[]

  @@index([surveyId])
  @@index([ploId])
}

model survey_responses {
  id          Int              @id @default(autoincrement())
  surveyId    Int
  studentId   Int
  submittedAt DateTime         @default(now())
  survey      surveys          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  student     students         @relation(fields: [studentId], references: [id])
  answers     survey_answers[]

  @@unique([surveyId, studentId])
  @@index([surveyId])
  @@index([studentId])
}

model survey_answers {
  id          Int              @id @default(autoincrement())
  responseId  Int
  questionId  Int
  ratingValue Int?
  textValue   String?
  response    survey_responses @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question    survey_questions @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@index([responseId])
  @@index([questionId])
}

enum survey_status {
  draft
  active
  closed
}

enum survey_question_type {
  rating
  text
}
